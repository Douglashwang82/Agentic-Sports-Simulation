# Database settings
# Replace with your actual database connection string
# For Docker setup (default): 
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agentic_hoops

# Redis settings
REDIS_URL=redis://localhost:6379/0

# Google Gemini settings
# Obtain from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Local server settings
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://127.0.0.1:5173

# File uploads
UPLOAD_DIR=./storage
